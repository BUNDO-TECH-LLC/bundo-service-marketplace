# For production host configuration (items 1–7), see `.env.production.example` in this folder.

NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Runtime: transaction pooler (Supabase port 6543). Migrations: session pooler (port 5432, same host).
DATABASE_URL=""
# Optional; defaults to DATABASE_URL. For migrate deploy, use the pooler host on :5432 (see db:migrate:deploy:pooler).
DIRECT_URL=""

FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Cloudinary (Dashboard → Product environment credentials). No spaces after values.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Paystack: use test secret sk_test_... from Dashboard → Settings → API Keys & Webhooks.
# If PAYSTACK_SECRET_KEY is set, PAYSTACK_CALLBACK_URL is required (server will not start without it).
# Use the exact URL users return to after checkout (your Vite dev URL or production site).
# Example for local dev:
PAYSTACK_CALLBACK_URL="http://localhost:5173/workspace/bookings"
# Leave PAYSTACK_SECRET_KEY empty until you are ready to test payments (otherwise omit CALLBACK above only if key is empty).
PAYSTACK_SECRET_KEY=""

PLATFORM_FEE_PERCENT=10

# Optional error reporting (Sentry). Leave empty to disable.
# SENTRY_DSN=

# Non-production only: allow confirming payments as PAID_HELD without calling Paystack
# when PAYSTACK_SECRET_KEY is unset (local UI demos). Never enable in production.
# ALLOW_PAYMENT_SIMULATION=true
