# Copy to your host’s secret env (do not commit real values).
# Checklist items 1–7: Postgres, migrate deploy, NODE_ENV, CORS, Firebase, Cloudinary, Paystack live key.

# (3) Production runtime
NODE_ENV=production
PORT=3000

# (4) Browser origins allowed to call this API (HTTPS only, comma-separated).
# Example: https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://bundo-service-marketplace.vercel.app
# Optional: comma-separated Vercel preview URLs if you test previews against production API
# CORS_EXTRA_ORIGINS=
# CORS_ALLOW_VERCEL_PREVIEWS=false

# (1) Managed PostgreSQL — use the provider’s connection strings (often identical).
# Must not use localhost/127.0.0.1 as the DB host in production (enforced in env.ts).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# (5) Firebase Admin — same project as production web clients.
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# (6) Cloudinary — production (or shared) cloud.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# (7) After Paystack activates live: use sk_live_... and an HTTPS callback.
PAYSTACK_SECRET_KEY=""
# Paystack appends ?reference=... — client verifies after sign-in and opens bookings.
# Must be HTTPS in production (Render will exit on start if this is http://localhost).
PAYSTACK_CALLBACK_URL="https://bundo-service-marketplace.vercel.app/workspace/bookings"
# Configure this in Paystack Dashboard → Settings → API Keys & Webhooks.
PAYSTACK_WEBHOOK_URL="https://bundo-service-marketplace.onrender.com/payments/webhooks/paystack"

PLATFORM_FEE_PERCENT=10

# Sentry (recommended for launch)
# SENTRY_DSN=

# App Check: enable on API only after VITE_FIREBASE_APP_CHECK_SITE_KEY is set on Vercel
# FIREBASE_APP_CHECK_ENFORCE=false

# Dojah identity verification (optional until merchant approval).
# When both are set, the API will call Dojah on KYC submit; otherwise submissions stay manual review.
# DOJAH_APP_ID=
# DOJAH_SECRET_KEY=

# Never enable in production.
# ALLOW_PAYMENT_SIMULATION=
