# Set these in your host before `npm run build` (Vite inlines at build time).
# Never commit real secrets.

# Production API. Prefer the same-origin Vercel proxy so browsers call bundo.ng
# instead of connecting directly to the Render hostname.
VITE_API_BASE_URL=/api

# Firebase web app (same project as server Firebase Admin).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Web push (Firebase Console → Cloud Messaging → Web Push certificates).
VITE_FIREBASE_VAPID_KEY=

# Sentry (recommended for launch)
# VITE_SENTRY_DSN=

# Firebase App Check reCAPTCHA v3 site key
# VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Paystack checkout is initialized by the API and uses Paystack-hosted redirect.
# Do not put PAYSTACK_SECRET_KEY here. The public key is not required by the current client flow.
