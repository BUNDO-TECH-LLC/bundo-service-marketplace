# Must match where the Express API runs (same origin you use in the browser).
VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_VAPID_KEY=your_firebase_web_push_certificate_key_pair
# Optional for the current app: checkout uses Paystack-hosted pay + redirect; only the server needs the secret key.
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_...

# Optional error reporting (Sentry). Leave empty to disable.
# VITE_SENTRY_DSN=
