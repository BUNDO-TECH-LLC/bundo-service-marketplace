{
  "rewrites": [
    {
      "source": "/__/auth/(.*)",
      "destination": "https://bundo-marketplace.firebaseapp.com/__/auth/$1"
    },
    {
      "source": "/__/firebase/init.json",
      "destination": "https://bundo-marketplace.firebaseapp.com/__/firebase/init.json"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
